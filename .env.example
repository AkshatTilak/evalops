# App Configuration
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Database Configuration
# Relational Database URL (e.g. postgresql://user:pass@host:port/db)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evalops

# Vector Database Configuration
# Qdrant URL for local vector memory index
QDRANT_URL=http://localhost:6333

# LLM Providers & API Keys
# API key for OpenRouter (used for routing/gateway tests)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Observability & Tracing (LangSmith / Phoenix)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=evalops-harness
